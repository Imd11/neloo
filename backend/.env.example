# =============================================================================
# Neloo backend environment
# Copy this file to backend/.env for local development.
# Never commit backend/.env, production secrets, or provider keys.
# =============================================================================

# =============================================================================
# Server / deployment
# =============================================================================

# Railway sets PORT automatically. Local LangGraph dev usually uses 2024.
PORT=2024

# Public URLs used for callbacks, file links, and CORS.
API_BASE_URL=http://localhost:2024
FRONTEND_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Shared usage limits. Redis is mandatory in production and optional only for
# single-process local development.
RATE_LIMIT_REDIS_URL=
RATE_LIMIT_NAMESPACE=neloo
TRUSTED_PROXY_HOPS=0
MODEL_RUNS_PER_10_MINUTES=30
IMAGE_RUNS_PER_10_MINUTES=20
E2B_RUNS_PER_10_MINUTES=20
DAILY_BUDGET_UNITS=200

# Optional LangGraph internals.
LANGGRAPH_API_URL=http://localhost:2024
LANGGRAPH_INTERNAL_URL=
LANGGRAPH_DEFAULT_GRAPH_ID=data_analyst
# false keeps startup lighter while still exposing public selector graph IDs.
# true eagerly builds every configured canonical and hidden legacy model graph.
NELOO_BUILD_ALL_MODEL_GRAPHS=false
# true builds real -web-dev and -fortune variants; false aliases variants to base graphs.
NELOO_BUILD_VARIANT_GRAPHS=false
ENABLE_HITL=false

# =============================================================================
# Authentication
# =============================================================================
# By default every authenticated route requires a valid Supabase JWT
# (SUPABASE_JWT_SECRET must be set). For single-user LOCAL development without
# Guest sessions let a self-hosted instance run without a login page. Generate
# one random value and set the identical secret in frontend/.env.local.
# Do not expose this value with a NEXT_PUBLIC_ prefix.
ALLOW_ANONYMOUS=false
ANONYMOUS_SESSION_SECRET=
# Local development only. Allows raw local-dev tokens when no guest-session
# secret is configured. Keep false for public deployments.
ALLOW_INSECURE_LOCAL_TOKENS=false

# Connected Apps (optional): add your Composio key and the OAuth auth-config IDs
# created in your own Composio workspace. Example:
# COMPOSIO_AUTH_CONFIGS_JSON={"github":"ac_your_github_config","gmail":"ac_your_gmail_config"}
COMPOSIO_API_KEY=
COMPOSIO_AUTH_CONFIGS_JSON=
# Exact app/action policy. Missing or invalid JSON denies every execute action.
COMPOSIO_ALLOWED_ACTIONS_JSON={"gmail":{"read":["GMAIL_FETCH_EMAILS"],"write":["GMAIL_SEND_EMAIL"]}}

# =============================================================================
# Chat model provider configuration
# Configure at least one provider to run the agent. The top-left model selector
# shows one canonical entry per provider; use *_MODEL to choose the exact model.
# =============================================================================

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-pro

# Qwen / DashScope (OpenAI-compatible)
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen3.7-max

# MiniMax through an Anthropic-compatible endpoint.
MINIMAX_API_KEY=
MINIMAX_ANTHROPIC_BASE_URL=https://api.minimax.io/anthropic
MINIMAX_MODEL=MiniMax-M2.7

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODEL=claude-opus-4-8

# OpenAI, also used for optional RAG embeddings.
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-5.5

# Gemini through Google's OpenAI-compatible endpoint. You may point this at a
# compatible gateway instead when needed.
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
GEMINI_MODEL=gemini-3.1-pro-preview

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=meta-llama/llama-4-maverick

# Z.AI / GLM (OpenAI-compatible)
ZHIPU_API_KEY=
ZHIPU_BASE_URL=https://api.z.ai/api/paas/v4
ZHIPU_MODEL=GLM-5.2

# Custom OpenAI-compatible provider
CUSTOM_OPENAI_API_KEY=
CUSTOM_OPENAI_BASE_URL=
CUSTOM_OPENAI_MODEL=

# Custom Anthropic-compatible provider
CUSTOM_ANTHROPIC_API_KEY=
CUSTOM_ANTHROPIC_BASE_URL=
CUSTOM_ANTHROPIC_MODEL=

# Optional agent-icon image generation. Uses Gemini Nano Banana 2 when this
# key is set, or reuses GEMINI_API_KEY. OpenAI is the fallback when configured.
GEMINI_IMAGE_API_KEY=
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image

# Legacy compatible gateway variables. Existing deployments may keep using
# these; new deployments should prefer the canonical variables above.
MINIMAX_BASE_URL=https://api.minimaxi.com/v1
NEWAPI_API_KEY=
NEWAPI_BASE_URL=
NEWAPI_ANTHROPIC_BASE_URL=

# =============================================================================
# Sandbox execution
# =============================================================================

# Options: e2b, e2b-sync, e2b-async, local. (docker is planned, not implemented.)
# Use local only for trusted local development; it has no real isolation.
SANDBOX_MODE=local

# SANDBOX_MODE=local runs user code directly on the host. Acknowledge the risk
# with ALLOW_LOCAL_SANDBOX=true. Guest mode does not enable host code execution.
# Without it, the server refuses to use local mode. Use e2b for public deploys.
ALLOW_LOCAL_SANDBOX=true

# Required when SANDBOX_MODE uses E2B.
E2B_API_KEY=

# =============================================================================
# Search, tracing, and app integrations
# =============================================================================

TAVILY_API_KEY=

LANGSMITH_API_KEY=
LANGSMITH_TRACING_V2=false
LANGSMITH_PROJECT=neloo

# =============================================================================
# Supabase storage / database
# =============================================================================

# Backend service access. Service keys are server-only secrets.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=

# Required only when you verify Supabase JWTs from a real auth flow.
SUPABASE_JWT_SECRET=

# Required only for production persistence with backend/langgraph.production.json.
# The default local backend/langgraph.json does not require this value.
# Railway Postgres normally provides DATABASE_URL automatically.
DATABASE_URL=

# Alternative for Supabase Postgres when DATABASE_URL is not set.
SUPABASE_DB_HOST=db.your-project-ref.supabase.co
SUPABASE_DB_PASSWORD=

# =============================================================================
# File and image storage
# =============================================================================

# Stable secret keys are required in production so signed URLs survive restarts.
FILE_SECRET_KEY=change-me-to-a-random-32-byte-secret
IMAGE_SECRET_KEY=change-me-to-a-random-32-byte-secret

# Force local disk storage instead of Supabase Storage.
FILE_USE_LOCAL_STORAGE=true
IMAGE_USE_LOCAL_STORAGE=true
