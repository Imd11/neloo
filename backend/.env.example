# =============================================================================
# Neloo backend environment
# Copy this file to backend/.env for local development.
# Never commit backend/.env, production secrets, or provider keys.
# =============================================================================

# =============================================================================
# Server / deployment
# =============================================================================

# Railway sets PORT automatically. Local LangGraph dev usually uses 2024.
PORT=2024

# Public URLs used for callbacks, file links, and CORS.
API_BASE_URL=http://localhost:2024
FRONTEND_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Optional LangGraph internals.
LANGGRAPH_API_URL=http://localhost:2024
LANGGRAPH_INTERNAL_URL=
LANGGRAPH_DEFAULT_GRAPH_ID=data_analyst
ENABLE_HITL=false

# =============================================================================
# Model provider API keys
# Configure at least one provider to run the agent.
# =============================================================================

# DeepSeek
DEEPSEEK_API_KEY=

# Qwen / DashScope (OpenAI-compatible)
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# MiniMax
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimaxi.com/v1
MINIMAX_ANTHROPIC_BASE_URL=

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# OpenAI, also used for optional RAG embeddings.
OPENAI_API_KEY=

# Zhipu / GLM (OpenAI-compatible)
ZHIPU_API_KEY=
ZHIPU_BASE_URL=

# Generic OpenAI-compatible / Anthropic-compatible gateway.
NEWAPI_API_KEY=
NEWAPI_BASE_URL=
NEWAPI_ANTHROPIC_BASE_URL=

# Tu-Zi or another compatible gateway.
TUZI_API_KEY=
TUZI_BASE_URL=https://api.tu-zi.com/v1
TUZI_ANTHROPIC_API_KEY=
TUZI_ANTHROPIC_BASE_URL=

# =============================================================================
# Sandbox execution
# =============================================================================

# Options: e2b, e2b-sync, e2b-async, local, docker.
# Use local only for trusted local development; it has no real isolation.
SANDBOX_MODE=local

# Required when SANDBOX_MODE uses E2B.
E2B_API_KEY=

# =============================================================================
# Search, tracing, and app integrations
# =============================================================================

TAVILY_API_KEY=

LANGSMITH_API_KEY=
LANGSMITH_TRACING_V2=false
LANGSMITH_PROJECT=neloo

COMPOSIO_API_KEY=

# =============================================================================
# Supabase storage / database
# =============================================================================

# Backend service access. Service keys are server-only secrets.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=

# Required only when you verify Supabase JWTs from a real auth flow.
SUPABASE_JWT_SECRET=

# Database persistence for LangGraph checkpoints and thread history.
# Railway Postgres normally provides DATABASE_URL automatically.
DATABASE_URL=

# Alternative for Supabase Postgres when DATABASE_URL is not set.
SUPABASE_DB_HOST=db.your-project-ref.supabase.co
SUPABASE_DB_PASSWORD=

# =============================================================================
# File and image storage
# =============================================================================

# Stable secret keys are required in production so signed URLs survive restarts.
FILE_SECRET_KEY=change-me-to-a-random-32-byte-secret
IMAGE_SECRET_KEY=change-me-to-a-random-32-byte-secret

# Force local disk storage instead of Supabase Storage.
FILE_USE_LOCAL_STORAGE=true
IMAGE_USE_LOCAL_STORAGE=true
