# =============================================================================
# Model Provider API Keys
# =============================================================================
# Configure one or more model providers. Models with configured API keys
# will be available in the frontend model selector dropdown.

# DeepSeek API (models: deepseek-chat, deepseek-reasoner)
DEEPSEEK_API_KEY="your-deepseek-api-key"

# Qwen/DashScope API (models: qwen-plus, qwen3-max)
# Uses OpenAI-compatible mode
QWEN_API_KEY="your-qwen-api-key"
QWEN_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"

# MiniMax API (models: minimax-m2 / MiniMax-M2.1)
# Uses OpenAI-compatible mode
MINIMAX_API_KEY="your-minimax-api-key"
MINIMAX_BASE_URL="https://api.minimaxi.com/v1"

# Anthropic API (Alternative - not exposed in model selector)
ANTHROPIC_API_KEY="your-anthropic-api-key"
ANTHROPIC_BASE_URL="https://api.anthropic.com"

# OpenAI API (Alternative - not exposed in model selector)
OPENAI_API_KEY="your-openai-api-key"

# =============================================================================
# Sandbox Execution
# =============================================================================

# Sandbox mode: "e2b" (cloud), "local" (subprocess), "docker" (container)
SANDBOX_MODE="e2b"

# E2B API Key (required for SANDBOX_MODE=e2b)
E2B_API_KEY="your-e2b-api-key"

# =============================================================================
# Web Search
# =============================================================================

# Tavily API Key (for web search tool)
TAVILY_API_KEY="your-tavily-api-key"

# =============================================================================
# LangSmith Tracing (Optional)
# =============================================================================

LANGSMITH_API_KEY="your-langsmith-api-key"
LANGSMITH_TRACING_V2="false"
LANGSMITH_PROJECT="data-analyst-agent"

# =============================================================================
# Supabase Storage (for production file storage)
# =============================================================================

# Project URL
SUPABASE_URL="https://your-project.supabase.co"

# Service Role Key (for server-side storage access)
SUPABASE_SERVICE_KEY="your-service-role-key"
