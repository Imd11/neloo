# Backend API URL.
# Local example: http://localhost:2024
# Production example: https://api.yourdomain.com
NEXT_PUBLIC_API_URL=http://localhost:2024

# Default LangGraph assistant / graph ID. The built-in graph currently keeps
# the historical ID "data_analyst" even though Neloo is a general agent.
NEXT_PUBLIC_ASSISTANT_ID=data_analyst

# Supabase browser client. Leave empty to disable Supabase-backed frontend
# features (login, persistent agent library, triggers) — the rest of the app
# (chat, files, data analysis) works without it. Fill in to enable.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional LangSmith key for deployed LangGraph clients.
NEXT_PUBLIC_LANGSMITH_API_KEY=

# Optional Google Drive Picker values. These are public browser values; restrict
# API keys by HTTP referrer and OAuth client by authorized origins.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
NEXT_PUBLIC_GOOGLE_API_KEY=

# Server-side image generation/editing keys for Next.js API routes.
# Nano Banana 2 uses the official Gemini Interactions API.
GEMINI_IMAGE_API_KEY=
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com
OPENAI_IMAGE_MODEL=gpt-image-2
